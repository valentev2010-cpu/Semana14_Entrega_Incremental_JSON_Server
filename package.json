{
  "name": "semana14-entrega-incremental-json-server",
  "version": "1.0.0",
  "description": "Semana 14 - Entrega incremental del sitio/proyecto con Vite, JSON Server, Bootstrap, SweetAlert2 y Chart.js.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "db": "json-server --watch db.json --port 3001",
    "start": "concurrently \"npm run db\" \"npm run dev\"",
    "check": "node scripts/check-project.js",
    "reset-db": "node scripts/reset-db.js"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "chart.js": "^4.4.4",
    "sweetalert2": "^11.14.4"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "json-server": "^1.0.0-beta.3",
    "vite": "^5.4.10"
  }
}
